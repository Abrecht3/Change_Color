    <style name="AppPink" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimaryVariant">#880E4F</item>
        <item name="colorPrimary">@color/rosa_primary</item>
        <item name="android:windowBackground">@color/rosa_fondo</item>
