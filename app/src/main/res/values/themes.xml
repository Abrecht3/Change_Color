    <style name="AppYellow" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="android:statusBarColor">@color/amarillo_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/amarillo_primary</item>
        <item name="android:windowBackground">@color/amarillo_fondo</item>
        <item name="android:textColorPrimary">#000000</item>
    </style>

    <style name="AppBlack" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/negro_primary</item>
        <item name="android:windowBackground">@color/negro_fondo</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
    </style>

</resources>