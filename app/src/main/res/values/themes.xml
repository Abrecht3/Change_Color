<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="AppRed" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/rojo_primary</item>
        <item name="android:windowBackground">@color/rojo_fondo</item>
        <item name="android:textColorPrimary">#4a0000</item>
    </style>

    <style name="AppBlue" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/azul_primary</item>
        <item name="android:windowBackground">@color/azul_fondo</item>
        <item name="android:textColorPrimary">#0D47A1</item>
    </style>

    <style name="AppGreen" parent="Theme.AppCompat.Light.DarkActionBar">
